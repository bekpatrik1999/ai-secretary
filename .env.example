# =============================================================================
# AI Secretary — environment configuration
# Target host: secr-app-d01  (Ubuntu 22.04, 16 vCPU / 32 GB RAM / 350 GB SSD)
# Server IP : 172.16.7.215
# =============================================================================

# ---- HTTP server (FastAPI / Uvicorn) ----------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2

# ---- PostgreSQL (runs in Docker, published on the loopback only) -----------
POSTGRES_USER=aisec
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aisec
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aisec:change-me-strong-password@127.0.0.1:5432/aisec

# ---- MinIO (object storage, runs in Docker, loopback-only) -----------------
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=meetings
MINIO_CONSOLE_PORT=9001

# ---- Whisper (faster-whisper, runs in the FastAPI process on CPU) ----------
# tiny | base | small | medium | large-v3
WHISPERX_MODEL=large-v3

# ---- Ollama (LLM backend for protocol generation) --------------------------
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
