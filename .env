# =============================================================================
# AI Secretary — environment configuration (PRODUCTION on secr-app-d01)
#
# This file is tracked in git as a ready-to-edit template.
# Replace every *change-me-*  placeholder with a real secret on the server
# BEFORE running `sudo systemctl start ai-secretary` for the first time.
# Never commit real secrets back into this file.
# =============================================================================

APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=2

POSTGRES_USER=aisec
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aisec
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aisec:change-me-strong-password@127.0.0.1:5432/aisec

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=meetings
MINIO_CONSOLE_PORT=9001

WHISPERX_MODEL=large-v3

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
